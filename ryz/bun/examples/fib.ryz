// Recursion, control flow, arithmetic, mutability — exercises the real evaluator.
import "std/fmt";

fn fib(n: i64) -> i64 {
    if n < 2 { return n; }
    return fib(n - 1) + fib(n - 2);
}

fn main() -> i32 {
    let mut i: i64 = 0;
    while i <= 10 {
        fmt.println("fib", i, "=", fib(i));
        i = i + 1;
    }
    return 0;
}
