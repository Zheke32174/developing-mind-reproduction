#!/usr/bin/env bash
# RYZ launcher — runs the Bun reference implementation with the REAL bun,
# never the /usr/local/bin/bun -> node shim. Resolves bun robustly.
set -uo pipefail
RYZ_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." 2>/dev/null && pwd)"
ENTRY="$RYZ_HOME/bun/src/ryz.ts"

pick_bun() {
  for b in "$HOME/.bun/bin/bun"; do
    [ -x "$b" ] && { echo "$b"; return; }
  done
  # PATH bun only if it is a real ELF bun, not the node shim.
  if command -v bun >/dev/null 2>&1; then
    local p; p="$(command -v bun)"
    if head -c4 "$p" 2>/dev/null | grep -q $'\x7fELF'; then echo "$p"; return; fi
  fi
  echo ""  # none
}

BUN="$(pick_bun)"
if [ -z "$BUN" ]; then
  echo "ryz: real Bun not found (need ~/.bun/bin/bun). Install: curl -fsSL https://bun.sh/install | bash" >&2
  exit 127
fi
exec "$BUN" "$ENTRY" "$@"
